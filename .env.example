# MLflow (tracking server from docker compose maps to host port 5000)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Feast online store (Postgres from docker compose; use host when feast apply runs on host)
FEAST_POSTGRES_HOST=127.0.0.1
FEAST_POSTGRES_PORT=5432
FEAST_POSTGRES_USER=aml
FEAST_POSTGRES_PASSWORD=aml
FEAST_POSTGRES_DATABASE=feast

# Convenience DSN (optional; config.py builds from parts above)
# FEAST_ONLINE_STORE_URL=postgresql://aml:aml@127.0.0.1:5432/feast
